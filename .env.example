# Example environment variables for Roofied (production). Copy and set real values in your
# host / IIS environment. Do NOT commit real secrets. ASP.NET Core maps "__" to nested keys.

# Database
ConnectionStrings__DefaultConnection=Server=YOUR_SQL_SERVER;Database=Roofied;User Id=roofied_app;Password=CHANGE_ME;Encrypt=True;TrustServerCertificate=False;MultipleActiveResultSets=true

# Security (REQUIRED in production) — strong random salt used to hash client IPs
Security__IpHashSalt=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# Bot protection (Cloudflare Turnstile)
Captcha__Enabled=true
Captcha__SiteKey=YOUR_TURNSTILE_SITE_KEY
Captcha__SecretKey=YOUR_TURNSTILE_SECRET_KEY

# Optional first-run administrator bootstrap (remove after first successful run)
SeedAdmin__Email=admin@your-domain.example
SeedAdmin__Password=CHANGE_ME_STRONG_PASSWORD

# Hosting
ASPNETCORE_ENVIRONMENT=Production
