{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Security": {
    "IpHashSalt": ""
  },
  "Captcha": {
    "Enabled": false,
    "SiteKey": "",
    "SecretKey": "",
    "VerifyUrl": "https://challenges.cloudflare.com/turnstile/v0/siteverify"
  },
  "LocationPrecision": {
    "DefaultGridSizeMeters": 1500,
    "MinGridSizeMeters": 500
  },
  "RateLimiting": {
    "ReportSubmit": { "Limit": 5, "WindowMinutes": 60 },
    "ChannelPost": { "Limit": 10, "WindowMinutes": 60 },
    "ContentFlag": { "Limit": 20, "WindowMinutes": 60 },
    "SignIn": { "Limit": 10, "WindowMinutes": 15 },
    "AccountRegister": { "Limit": 5, "WindowMinutes": 60 }
  },
  "SeedAdmin": {
    "Email": "",
    "Password": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
