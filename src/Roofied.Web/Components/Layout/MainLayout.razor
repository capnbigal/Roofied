@inherits LayoutComponentBase

<MudThemeProvider @ref="_themeProvider" @bind-IsDarkMode="_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider CloseButton="true" MaxWidth="MaxWidth.Medium" FullWidth="true" />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Surface">
        <MudLink Href="/" Underline="Underline.None" Color="Color.Inherit" Class="d-flex align-center mr-4">
            <MudIcon Icon="@Icons.Material.Filled.Shield" Class="mr-2" />
            <MudText Typo="Typo.h6">Roofied</MudText>
        </MudLink>

        @* Horizontal top navigation (desktop) *@
        <div class="d-none d-lg-flex align-center" style="gap:2px;">
            <MudButton Href="/" StartIcon="@Icons.Material.Filled.Map" Color="Color.Inherit">Map</MudButton>
            <MudButton Href="/report/new" StartIcon="@Icons.Material.Filled.AddLocationAlt" Color="Color.Inherit">Submit a report</MudButton>
            <MudButton Href="/reports" StartIcon="@Icons.Material.Filled.List" Color="Color.Inherit">Browse</MudButton>
            <MudButton Href="/channels" StartIcon="@Icons.Material.Filled.Forum" Color="Color.Inherit">Channels</MudButton>
            <MudButton Href="/resources" StartIcon="@Icons.Material.Filled.Emergency" Color="Color.Inherit">Resources</MudButton>

            <AuthorizeView Policy="@PolicyNames.CanModerateReports" Context="mod">
                <MudMenu StartIcon="@Icons.Material.Filled.Gavel" EndIcon="@Icons.Material.Filled.ArrowDropDown"
                         Label="Moderation" Color="Color.Inherit" Variant="Variant.Text">
                    <MudMenuItem Href="/moderator" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudMenuItem>
                    <MudMenuItem Href="/moderator/reports" Icon="@Icons.Material.Filled.FactCheck">Report queue</MudMenuItem>
                    <MudMenuItem Href="/moderator/posts" Icon="@Icons.Material.Filled.Forum">Post queue</MudMenuItem>
                    <MudMenuItem Href="/moderator/flags" Icon="@Icons.Material.Filled.Flag">Flags</MudMenuItem>
                </MudMenu>
            </AuthorizeView>
            <AuthorizeView Policy="@PolicyNames.CanAdministerPlatform" Context="adm">
                <MudMenu StartIcon="@Icons.Material.Filled.AdminPanelSettings" EndIcon="@Icons.Material.Filled.ArrowDropDown"
                         Label="Admin" Color="Color.Inherit" Variant="Variant.Text">
                    <MudMenuItem Href="/admin" Icon="@Icons.Material.Filled.Insights">Overview</MudMenuItem>
                    <MudMenuItem Href="/admin/users" Icon="@Icons.Material.Filled.People">Users &amp; roles</MudMenuItem>
                    <MudMenuItem Href="/admin/categories" Icon="@Icons.Material.Filled.Category">Categories</MudMenuItem>
                    <MudMenuItem Href="/admin/channels" Icon="@Icons.Material.Filled.Tune">Channels</MudMenuItem>
                    <MudMenuItem Href="/admin/resources" Icon="@Icons.Material.Filled.MenuBook">Resources</MudMenuItem>
                </MudMenu>
            </AuthorizeView>
        </div>

        <MudSpacer />

        <MudButton Href="/resources" StartIcon="@Icons.Material.Filled.Emergency" Color="Color.Error"
                   Variant="Variant.Filled" Size="Size.Large" Class="mr-2"
                   Style="font-weight:700; letter-spacing:.3px; box-shadow:0 2px 12px rgba(211,47,47,.55);">
            Get Help Now
        </MudButton>
        <MudTooltip Text="Toggle light/dark mode">
            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit" OnClick="@(() => _isDarkMode = !_isDarkMode)" aria-label="Toggle theme" />
        </MudTooltip>
        <AuthorizeView>
            <Authorized>
                <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" AriaLabel="Account menu">
                    <MudMenuItem Href="/account/my-reports">My reports</MudMenuItem>
                    <MudMenuItem Href="/account/my-posts">My posts</MudMenuItem>
                    <MudMenuItem Href="/Account/Manage">Account settings</MudMenuItem>
                    <MudDivider />
                    <MudMenuItem Href="/Account/Logout">Sign out</MudMenuItem>
                </MudMenu>
            </Authorized>
            <NotAuthorized>
                <MudButton Href="/Account/Login" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Login">Sign in</MudButton>
            </NotAuthorized>
        </AuthorizeView>

        @* Compact menu for small screens *@
        <MudMenu Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Class="d-flex d-lg-none" AriaLabel="Navigation menu">
            <MudMenuItem Href="/" Icon="@Icons.Material.Filled.Map">Map &amp; latest reports</MudMenuItem>
            <MudMenuItem Href="/report/new" Icon="@Icons.Material.Filled.AddLocationAlt">Submit a report</MudMenuItem>
            <MudMenuItem Href="/reports" Icon="@Icons.Material.Filled.List">Browse reports</MudMenuItem>
            <MudMenuItem Href="/channels" Icon="@Icons.Material.Filled.Forum">Community channels</MudMenuItem>
            <MudMenuItem Href="/resources" Icon="@Icons.Material.Filled.Emergency">Get help / resources</MudMenuItem>
            <MudMenuItem Href="/about" Icon="@Icons.Material.Filled.Favorite">About</MudMenuItem>
            <AuthorizeView Policy="@PolicyNames.CanModerateReports" Context="modm">
                <MudDivider />
                <MudMenuItem Href="/moderator" Icon="@Icons.Material.Filled.Gavel">Moderation</MudMenuItem>
            </AuthorizeView>
            <AuthorizeView Policy="@PolicyNames.CanAdministerPlatform" Context="admm">
                <MudMenuItem Href="/admin" Icon="@Icons.Material.Filled.AdminPanelSettings">Administration</MudMenuItem>
            </AuthorizeView>
        </MudMenu>
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">
            @Body
        </MudContainer>
        <footer class="py-4 px-4 mt-2" style="text-align:center;">
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                Roofied — a community safety project. ·
                <MudLink Href="/about" Typo="Typo.caption">About</MudLink> ·
                <MudLink Href="/resources" Typo="Typo.caption">Get help &amp; resources</MudLink>
            </MudText>
        </footer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _isDarkMode;
    private MudThemeProvider _themeProvider = null!;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#3a5a78",      // calm slate blue
            Secondary = "#5b8a72",    // muted green
            AppbarBackground = "#ffffff",
            AppbarText = "#1f2933",
            Background = "#f7f8fa",
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#7fa6c4",
            Secondary = "#8fbfa6",
        },
        Typography = new Typography
        {
            Default = new DefaultTypography { FontFamily = new[] { "Roboto", "Helvetica", "Arial", "sans-serif" } },
        },
    };
}
