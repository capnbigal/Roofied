<MudItem xs="12" sm="6" md="3">
    <MudCard Outlined="true" Class="h-100" Style="cursor:pointer" @onclick="Navigate">
        <MudCardContent>
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@Title</MudText>
                    <MudText Typo="Typo.h4">@Value</MudText>
                </div>
                <MudIcon Icon="@Icon" Color="@Color" Size="Size.Large" />
            </div>
        </MudCardContent>
    </MudCard>
</MudItem>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public int Value { get; set; }
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Info;
    [Parameter] public Color Color { get; set; } = Color.Primary;
    [Parameter] public string? Href { get; set; }
    [Inject] private NavigationManager Nav { get; set; } = null!;

    private void Navigate()
    {
        if (!string.IsNullOrWhiteSpace(Href))
            Nav.NavigateTo(Href);
    }
}
