@* Calm, non-sensational safety notice. Shown above the map and on submission pages. *@
<MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-3"
          Icon="@Icons.Material.Filled.HealthAndSafety">
    <MudText Typo="Typo.body2">
        If you are in immediate danger or need urgent medical help, contact your local emergency services now.
        This site is not a substitute for emergency, medical, police, or crisis support.
        <MudLink Href="/resources" Color="Color.Inherit"><b>Get help &amp; resources</b></MudLink>
    </MudText>
</MudAlert>
