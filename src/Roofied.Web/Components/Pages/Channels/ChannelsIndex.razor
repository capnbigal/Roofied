@page "/channels"
@inject IChannelService Channels

<PageTitle>Community channels</PageTitle>

<MudText Typo="Typo.h4" Class="mb-1">Community channels</MudText>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
    Moderated, supportive discussion. Please don't name or accuse specific people, venues, or businesses,
    and avoid sharing personal information. All posts are reviewed before they appear.
</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_channels.Count == 0)
{
    <MudPaper Outlined="true" Class="pa-8 text-center mud-text-secondary">
        <MudText>No channels are available yet.</MudText>
    </MudPaper>
}
else
{
    <MudPaper Outlined="true">
        <MudList T="string" Class="py-0">
            @for (var i = 0; i < _channels.Count; i++)
            {
                var c = _channels[i];
                <MudListItem T="string" Href="@($"/channels/{c.Slug}")" Icon="@Icons.Material.Filled.Forum">
                    <div class="d-flex align-center justify-space-between" style="gap:16px;">
                        <div style="min-width:0;">
                            <div class="d-flex align-center" style="gap:8px;">
                                <MudText Typo="Typo.subtitle1">@c.Name</MudText>
                                @if (c.IsLocked)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text">Locked</MudChip>
                                }
                            </div>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">@c.Description</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@c.ApprovedPostCount @(c.ApprovedPostCount == 1 ? "post" : "posts")</MudText>
                        </div>
                        <MudButton Href="@($"/channels/{c.Slug}")" Variant="Variant.Filled" Color="Color.Primary"
                                   EndIcon="@Icons.Material.Filled.ChevronRight" Style="flex:0 0 auto;">Open</MudButton>
                    </div>
                </MudListItem>
                @if (i < _channels.Count - 1)
                {
                    <MudDivider />
                }
            }
        </MudList>
    </MudPaper>
}

@code {
    private bool _loading = true;
    private IReadOnlyList<ChannelDto> _channels = Array.Empty<ChannelDto>();

    protected override async Task OnInitializedAsync()
    {
        _channels = await Channels.GetChannelsAsync();
        _loading = false;
    }
}
