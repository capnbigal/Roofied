@page "/about"

<PageTitle>About Roofied</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="px-0">
    <MudText Typo="Typo.h4" Class="mb-3">About Roofied</MudText>

    <MudPaper Elevation="1" Class="pa-6">
        <div class="d-flex align-center mb-3" style="gap:10px;">
            <MudIcon Icon="@Icons.Material.Filled.Favorite" Color="Color.Error" />
            <MudText Typo="Typo.h6">For Melissa Anne</MudText>
        </div>

        <MudText Typo="Typo.body1" Class="mb-3">
            <b>Melissa Anne made me do it.</b>
        </MudText>
        <MudText Typo="Typo.body1" Class="mb-3">
            She woke me up off of a bar after I'd been roofied, and looked out for me when I couldn't look out
            for myself. I owe her my gratitude — and this project is for her, and for everyone who watches out
            for the people around them.
        </MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary">
            Roofied exists so people can share what happened, see patterns in their area, and help each other
            stay a little safer. Thank you, Melissa. 💛
        </MudText>
    </MudPaper>

    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mt-4">
        This site is not a substitute for emergency, medical, police, or crisis support.
        <MudLink Href="/resources"><b>Get help &amp; resources</b></MudLink>
    </MudAlert>
</MudContainer>
