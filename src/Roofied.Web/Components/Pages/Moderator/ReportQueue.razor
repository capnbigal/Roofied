@page "/moderator/reports"
@attribute [Authorize(Policy = PolicyNames.CanModerateReports)]
@inject IModerationService Moderation

<PageTitle>Report queue</PageTitle>

<MudText Typo="Typo.h4" Class="mb-3">Report queue</MudText>

<MudTabs Elevation="0" Rounded="true" Class="mb-3" @bind-ActivePanelIndex="_tab">
    <MudTabPanel Text="Needs review" />
    <MudTabPanel Text="Approved" />
    <MudTabPanel Text="Rejected" />
    <MudTabPanel Text="Archived" />
</MudTabs>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_items.Count == 0)
{
    <MudPaper Outlined="true" Class="pa-8 text-center mud-text-secondary">
        <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" />
        <MudText Class="mt-2">Nothing here right now.</MudText>
    </MudPaper>
}
else
{
    <MudTable Items="_items" Hover="true" Dense="true" Elevation="1">
        <HeaderContent>
            <MudTh>Reference</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Area</MudTh>
            <MudTh>Submitted</MudTh>
            <MudTh>Flags</MudTh>
            <MudTh>Status</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.ReferenceCode</MudTd>
            <MudTd>@context.IncidentTypeName</MudTd>
            <MudTd>@context.City</MudTd>
            <MudTd>@context.CreatedUtc.ToString("MMM d, yyyy")</MudTd>
            <MudTd>
                @if (context.AutoFlagCount > 0)
                {
                    <MudTooltip Text="Auto-detected potential PII/accusation"><MudIcon Icon="@Icons.Material.Filled.PrivacyTip" Color="Color.Warning" Size="Size.Small" /></MudTooltip>
                }
                @if (context.OpenFlagCount > 0)
                {
                    <MudBadge Content="context.OpenFlagCount" Color="Color.Error" Overlap="true"><MudIcon Icon="@Icons.Material.Filled.Flag" Size="Size.Small" /></MudBadge>
                }
            </MudTd>
            <MudTd><ReportStatusChip Status="context.Status" /></MudTd>
            <MudTd><MudButton Href="@($"/moderator/reports/{context.Id}")" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary">Review</MudButton></MudTd>
        </RowTemplate>
    </MudTable>

    <div class="d-flex justify-center mt-3">
        <MudPagination Count="@_pageCount" Selected="_page" SelectedChanged="OnPageChangedAsync" />
    </div>
}

@code {
    private int _tab;
    private int _lastTab = -1;
    private List<ModeratorReportListItemDto> _items = new();
    private int _page = 1;
    private const int PageSize = 20;
    private int _total;
    private int _pageCount => Math.Max(1, (int)Math.Ceiling(_total / (double)PageSize));
    private bool _loading = true;

    protected override async Task OnParametersSetAsync()
    {
        if (_tab != _lastTab)
        {
            _lastTab = _tab;
            _page = 1;
            await LoadAsync();
        }
    }

    private ReportStatus? StatusForTab() => _tab switch
    {
        1 => ReportStatus.Approved,
        2 => ReportStatus.Rejected,
        3 => ReportStatus.Archived,
        _ => null, // needs review (pending + needs clarification)
    };

    private async Task LoadAsync()
    {
        _loading = true;
        var paged = await Moderation.GetReportQueueAsync(StatusForTab(), _page, PageSize);
        _items = paged.Items.ToList();
        _total = paged.TotalCount;
        _loading = false;
    }

    private async Task OnPageChangedAsync(int page) { _page = page; await LoadAsync(); }
}
